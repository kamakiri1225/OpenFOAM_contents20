7
(
    minY
    {
        type            patch;
        inGroups        1 ( wall );
        nFaces          32;
        startFace       1584;
    }

    minZ
    {
        type            patch;
        inGroups        1 ( wall );
        nFaces          16;
        startFace       1616;
    }

    maxZ
    {
        type            patch;
        inGroups        1 ( wall );
        nFaces          16;
        startFace       1632;
    }

    heater_to_topAir
    {
        type            mappedWall;
        inGroups        1 ( wall );
        nFaces          160;
        startFace       1648;
        sampleMode      nearestPatchFace;
        sampleRegion    topAir;
        samplePatch     topAir_to_heater;
    }

    heater_to_rightSolid
    {
        type            mappedWall;
        inGroups        1 ( wall );
        nFaces          40;
        startFace       1808;
