    {
        ".*"
        {
            type    calculated;
            value   uniform 0;
        }
        defaultFaces
        {
            type            empty;
        }
    }
}

IDefault
{
    internalField   uniform 0;

    boundaryField
    {
        ".*"
        {
            type    greyDiffusiveRadiation;
            value   uniform 0;
        }
        defaultFaces
        {
            type            empty;
        }
    }
}


