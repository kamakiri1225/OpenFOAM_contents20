FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     chtMultiRegionFoam;

startFrom       latestTime;

startTime       0.001;

stopAt          endTime;

endTime         60;

deltaT          0.001;

writeControl    adjustable;

writeInterval   2;

purgeWrite      0;

writeFormat     ascii;

writePrecision  7;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

maxCo           1.0;

maxDi           1.0;

adjustTimeStep  yes;

functions
{
    wallHeatFlux_air
    {
        type            wallHeatFlux;
        libs            ("libfieldFunctionObjects.so");
        region          air;
        patches         (air_to_heatSource);
        writeControl    writeTime;
    }

    wallHeatFlux_heatSource
    {
        $wallHeatFlux_air
        region          heatSource;
        patches         (heatSource_to_air);
    }

    qInt_air_to_heatSource
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        region          air;
        enabled         true;
        log             true;
        writeControl    timeStep;
        writeInterval   1;
        writeFields     false;
        regionType      patch;
        name            air_to_heatSource;
        operation       areaIntegrate;
        fields          (wallHeatFlux);
    }

    qInt_heatSource_to_air
    {
        $qInt_air_to_heatSource
        region          heatSource;
        name            heatSource_to_air;
    }

    Tavg_air_to_heatSource
    {
        $qInt_air_to_heatSource
        operation       areaAverage;
        fields          (T);
    }

    Tavg_heatSource_to_air
    {
        $Tavg_air_to_heatSource
        region          heatSource;
        name            heatSource_to_air;
    }
}
// ************************************************************************* //
