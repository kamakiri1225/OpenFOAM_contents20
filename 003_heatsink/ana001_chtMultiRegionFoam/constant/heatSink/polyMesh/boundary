        type            mappedWall;
        inGroups        1(wall);
        nFaces          5590;
        startFace       221851;
        sampleMode      nearestPatchFace;
        sampleRegion    heatSource;
        samplePatch     heatSource_to_heatSink;
    }
    heatSink_to_air
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          39756;
        startFace       227441;
        sampleMode      nearestPatchFace;
        sampleRegion    air;
        samplePatch     air_to_heatSink;
    }
)

