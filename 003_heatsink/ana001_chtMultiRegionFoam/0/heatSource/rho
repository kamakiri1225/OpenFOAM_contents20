FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/heatSource";
    object      rho;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 8000;

boundaryField
{
    heatSource_to_basis
    {
        type            calculated;
        value           uniform 0;
    }
    heatSource_to_heatSink
    {
        type            calculated;
        value           uniform 0;
    }
    heatSource_to_air
    {
        type            calculated;
        value           uniform 0;
    }
}


