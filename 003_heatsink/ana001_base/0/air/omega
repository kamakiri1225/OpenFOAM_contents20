FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/air";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 -1 0 0 0 0 ];

internalField   uniform 5.6;

boundaryField
{
    YMin
    {
        type            inletOutlet;
        value           uniform 6.7082e-05;
        inletValue      uniform 0.67082;
    }
    ZMax
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    YMax
    {
        type            turbulentMixingLengthFrequencyInlet;
        value           uniform 0.67082;
        mixingLength    0.01;
    }
    XMin
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    ZMin
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    XMax
    {
        type            omegaWallFunction;
        value           $internalField;
    }
    air_to_heatsink
    {
        type            omegaWallFunction;
        value           $internalField;
    }
}


