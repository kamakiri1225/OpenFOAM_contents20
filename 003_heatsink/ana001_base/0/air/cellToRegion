FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/air";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    XMin
    {
        type            zeroGradient;
    }
    YMin
    {
        type            zeroGradient;
    }
    ZMax
    {
        type            zeroGradient;
    }
    YMax
    {
        type            zeroGradient;
    }
    ZMin
    {
        type            zeroGradient;
    }
    XMax
    {
        type            zeroGradient;
    }
    air_to_heatsink
    {
        type            calculated;
        value           uniform 0;
    }
}


