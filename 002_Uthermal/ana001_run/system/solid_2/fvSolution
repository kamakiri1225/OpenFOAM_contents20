solvers
{
    h
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.01;
    }

    hFinal
    {
        $h;
        relTol          0;
    }
}

PIMPLE
{
    nOuterCorrectors          10;
    nNonOrthogonalCorrectors  0;
}

relaxationFactors
{
    equations
    {
        "h.*"                 0.9;
    }
}
