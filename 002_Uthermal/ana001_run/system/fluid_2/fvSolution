solvers
{
    rho
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.05;
    }

    rhoFinal
    {
        $rho;
        relTol          0;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.001;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "(U|h|k|epsilon|R)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.01;
    }

    "(U|h|k|epsilon|R)Final"
    {
        $U;
        relTol          0;
    }
}

PIMPLE
{
    momentumPredictor         yes;
    nOuterCorrectors          10;
    nCorrectors               3;
    nNonOrthogonalCorrectors  0;

    pRefCell                  0;
    pRefValue                 100000;
}

relaxationFactors
{
    equations
    {
        "h.*"                 0.9;
        "U.*"                 0.7;
        "p_rgh.*"             0.3;
    }
}
