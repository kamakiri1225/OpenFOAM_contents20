FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/fluid_1";
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    f1_minX
    {
        type            calculated;
        value           uniform 0.01;
    }
    f1_minY
    {
        type            calculated;
        value           uniform 0.01;
    }
    f1_maxY
    {
        type            calculated;
        value           uniform 0.01;
    }
    defaultFaces
    {
        type            empty;
    }
    fluid_1_to_solid_1
    {
        type            calculated;
        value           uniform 0;
    }
}


