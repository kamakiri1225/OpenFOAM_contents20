FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0/fluid_1";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform ( 0 0 0 );

boundaryField
{
    f1_minX
    {
        type            fixedValue;
        value           uniform ( 0 0 0 );
    }
    f1_minY
    {
        type            fixedValue;
        value           uniform ( 0 0 0 );
    }
    f1_maxY
    {
        type            fixedValue;
        value           uniform ( 0 0 0 );
    }
    defaultFaces
    {
        type            empty;
    }
    fluid_1_to_solid_1
    {
        type            fixedValue;
        value           uniform ( 0 0 0 );
    }
}


