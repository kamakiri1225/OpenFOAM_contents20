FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0/solid_2";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0.01 0 0);

boundaryField
{
    s2_minY
    {
        type            calculated;
        value           uniform (0.01 0 0);
    }
    s2_maxY
    {
        type            calculated;
        value           uniform (0.01 0 0);
    }
    s2_maxX
    {
        type            calculated;
        value           uniform (0.01 0 0);
    }
    defaultFaces
    {
        type            empty;
    }
    solid_2_to_fluid_2
    {
        type            calculated;
        value           uniform (0 0 0);
    }
}


