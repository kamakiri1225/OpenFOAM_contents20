    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
    f2_maxY
    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
    defaultFaces
    {
        type            empty;
    }
    fluid_2_to_solid_2
    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
    fluid_2_to_solid_1
    {
        type            fixedFluxPressure;
        value           uniform 100000;
    }
}


