FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/solid_1";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    s1_minY
    {
        type            zeroGradient;
    }
    s1_maxY
    {
        type            zeroGradient;
    }
    defaultFaces
    {
        type            empty;
    }
    solid_1_to_fluid_1
    {
        type            calculated;
        value           uniform 0;
    }
    solid_1_to_fluid_2
    {
        type            calculated;
        value           uniform 0;
    }
}


