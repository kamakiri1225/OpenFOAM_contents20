FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     chtMultiRegionFoam;

startFrom       latestTime;

startTime       0.001;

stopAt          endTime;

endTime         3600;

deltaT          0.001;

writeControl    adjustable;

writeInterval   100;

purgeWrite      0;

writeFormat     ascii;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

maxCo           10.0;

// Maximum diffusion number
maxDi           10.0;

adjustTimeStep  yes;

functions
{
    // #include "vtkWrite"
    wallHeatFlux_fluid_1
    {
        type            wallHeatFlux;
        libs            ("libfieldFunctionObjects.so");
        region          fluid_1;
        patches         (fluid_1_to_solid_1);
        writeControl    writeTime;      
    }

    wallHeatFlux_solid_1
    {
        $wallHeatFlux_fluid_1
        region          solid_1;
        patches         (solid_1_to_fluid_1);
    }

    qAvg_fluid_1
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        region          fluid_1;
        writeControl    writeTime;   
        writeFields     false;   // 面上の場を書き出さず、集計値だけ出す
        regionType      patch;
        name            fluid_1_to_solid_1;
        operation       areaAverage;
        fields          (wallHeatFlux);
    }

    qAvg_solid_1
    {
        $qAvg_fluid_1
        region          solid_1;
        name            solid_1_to_fluid_1;    }


    qInt_fluid_1
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        region          fluid_1;
        writeControl    writeTime;   
        writeFields     false;   // 面上の場を書き出さず、集計値だけ出す
        regionType      patch;
        name            fluid_1_to_solid_1;
        operation       areaIntegrate;
        fields          (wallHeatFlux);
    }

    qInt_solid_1
    {
        $qInt_fluid_1
        region          solid_1;
        name            solid_1_to_fluid_1;
    }

    residuals_fluid_1
    {
        type                solverInfo;
        libs                ("libutilityFunctionObjects.so");
        writeControl        writeTime;
        region              fluid_1;
        fields   ( U h p_rgh );
        writeResidualFields yes;
    }
    residuals_fluid_2
    {
        $residuals_fluid_1
        region              fluid_2;
    }
    residuals_solid_1
    {
        type                solverInfo;
        libs                ("libutilityFunctionObjects.so");
        writeControl        writeTime;
        region              solid_1;
        fields   ( h );
        writeResidualFields yes;
    }
    residuals_solid_2   
    {
        $residuals_solid_1
        region              solid_2;
    }
    fieldMinMax_fluid_1
    {
        type                fieldMinMax;
        libs                (fieldFunctionObjects);
        mode                magnitude;
        fields              ( U T p );
        useUserTime         yes;
        region              fluid_1;
        writeControl        writeTime;
    }
    fieldMinMax_fluid_2
    {
        $fieldMinMax_fluid_1
        region              fluid_2;
    }
    fieldMinMax_solid_1
    {
        type                fieldMinMax;
        libs                (fieldFunctionObjects);
        mode                magnitude;
        fields              ( T p );
        useUserTime         yes;
        region              solid_1;
        writeControl        writeTime;
    }
    fieldMinMax_solid_2
    {
        $fieldMinMax_solid_1
        region              solid_2;
    }
}

// ************************************************************************* //
